# Google Earth Engine (required for satellite analysis)
GHOSTWATCH_GEE_PROJECT=your-gee-project-id

# Spectral thresholds (optional — defaults in ghostwatch.yaml)
# GHOSTWATCH_NDBI_CHANGE_THRESHOLD=0.10
# GHOSTWATCH_NDVI_CHANGE_THRESHOLD=0.15
# GHOSTWATCH_BSI_CHANGE_THRESHOLD=0.10
# GHOSTWATCH_GHOST_CONFIDENCE_THRESHOLD=0.70

# API settings (optional)
# GHOSTWATCH_CORS_ORIGINS=http://localhost:3000
# GHOSTWATCH_ADMIN_API_KEY=
